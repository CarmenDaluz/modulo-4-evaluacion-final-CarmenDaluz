
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Carrito de compra de mi libreria</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body>
    <%- include('./partials/header') %>
    <h1>Carrito </h1>
    <div >
        <% carrito.forEach((element) => { %>
            
            <div class="finalCart">
                <h3><%= element.name %></h3>
                <p><%= element.cantidad %> </p>
                <p><%= element.price %> </p>
            </div>
            
        <% }) %>
    </div>
    <a href="/products">Volver atrás</a>
</body>
</html>